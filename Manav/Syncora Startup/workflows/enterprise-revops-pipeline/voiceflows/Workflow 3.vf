        "6933de8438f22f865bba1a6c": {
          "name": "Business Email Validation",
          "settings": {
            "model": "claude-4-sonnet",
            "maxTokens": 5000,
            "temperature": 0.3,
            "reasoningEffort": null
          },
          "cardTool": null,
          "apiTools": [],
          "pathTools": [
            {
              "id": "6933e07b38f22f865bba1aa9",
              "name": "Success",
              "variables": [
                {
                  "name": "valid",
                  "required": true,
                  "description": null
                }
              ],
              "description": "exit when the output is \"valid\""
            },
            {
              "id": "6933e09c38f22f865bba1aaa",
              "name": "Failure",
              "variables": [
                {
                  "name": "invalid",
                  "required": true,
                  "description": null
                }
              ],
              "description": "Exit when the output is \"invalid\""
            }
          ],
          "buttonTool": null,
          "description": "",
          "carouselTool": null,
          "instructions": "You are an Email Validation Engine. Your job is to determine if {business_email} is a  valid \"Business\" email or a valid \"Personal\" email or \"Invalid Format\"\r\n\r\nInstructions:\r\n-If the domain is gmail.com, yahoo.com, hotmail.com, outlook.com, icloud.com, aol.com, protonmail.com, or live.com,  store \"true\" in variable invalid.\r\n-  If the input is not a standard email address (e.g. missing \"@\", missing \".com/.net/etc\") , store \"true\" in variable invalid.\n-  If it is a valid email format AND the domain is NOT in the personal list above,store \"true\" in variable valid.\r\n- ONLY store the word \"valid\" or \"invalid\". Do not add punctuation.\n\n",
          "functionTools": [],
          "webSearchTool": {
            "enabled": false,
            "description": "Search the web when external, fresh, or currently updated information is required to answer the user's query accurately."
          },
          "callForwardTool": null,

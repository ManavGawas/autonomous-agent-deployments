    {
      "id": "69425fd75d50142b9a48a39d",
      "discriminatorID": "69425fd75d50142b9a48a39c",
      "text": [
        {
          "text": [
            "I encountered a momentary glitch syncing with our central calendar, but don't worry—I have securely logged your details in our backup system.\n\nA member of our team will review your information manually and reach out to you shortly to finalize the next steps. Thank you for chatting with Syncora!"
          ]
        }
      ],
      "condition": null,
      "delay": null,
      "createdAt": "2025-12-29T08:22:50.000Z"
    },

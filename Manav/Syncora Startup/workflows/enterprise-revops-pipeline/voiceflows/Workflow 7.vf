    {
      "id": "6933d95f7683b6df1ca4a521",
      "promptID": "6933d95f7683b6df1ca4a520",
      "pairID": null,
      "type": "role",
      "data": {
        "role": "system",
        "content": [
          {
            "text": [
              "You are a professional B2B Sales Concierge. Your tone is helpful but professional. You need to collect the user's contact information."
            ]
          }
        ]
      },
      "createdAt": "2025-12-06T07:21:04.000Z"
    },
    {
      "id": "6933d95f7683b6df1ca4a522",
      "promptID": "6933d95f7683b6df1ca4a520",
      "pairID": null,
      "type": "role",
      "data": {
        "role": "user",
        "content": [
          {
            "text": [
              "Ask the user for their business email address. Politely mention that we require a corporate domain (no Gmail or Yahoo) to route them to the enterprise team. Keep it short."
            ]
          }
        ]
      },
      "createdAt": "2025-12-06T07:21:04.000Z"
    },

    {
      "id": "692c371109ca61000745e291",
      "name": "Ask company size",
      "createdByID": 1861622,
      "folderID": null,
      "settings": {
        "model": "claude-4-sonnet",
        "maxTokens": 5000,
        "temperature": 0.3,
        "reasoningEffort": null
      },
      "description": null,
      "instructions": [
        {
          "text": [
            "Ask: \"Thanks. Just one more question: roughly how many employees work at your company?\" Capture input and save as {company_size}. Validate that the input is a numeric value, greater than zero."
          ]
        }
      ],
      "pathToolOrder": [
        "692c371109ca61000745e2a2",
        "692c371109ca61000745e2a3"

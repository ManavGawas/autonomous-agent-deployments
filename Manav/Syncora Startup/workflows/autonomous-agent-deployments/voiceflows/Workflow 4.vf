                    {
                      "children": [
                        {
                          "text": "I encountered a momentary glitch syncing with our central calendar, but don't worry—I have securely logged your details in our backup system.\n\nA member of our team will review your information manually and reach out to you shortly to finalize the next steps. Thank you for chatting with Syncora!"
                        }
                      ]
                    }
                  ],
                  "delay": null
                },
                "condition": null
              }
            ]
          }
        },

        "693289d02d0514000798562b": {
          "name": "Product question handling",
          "settings": {
            "model": "claude-4-sonnet",
            "maxTokens": 5000,
            "temperature": 0.3,
            "reasoningEffort": null
          },
          "cardTool": null,
          "apiTools": [],
          "pathTools": [
            {
              "id": "693289d02d05140007985639",
              "name": "User's question answered",
              "variables": [],
              "description": "The product question has been resolved.",
              "messages": null
            },
            {
              "id": "693289d02d0514000798563a",
              "name": "Further escalation needed",
              "variables": [],
              "description": "The user's needs are not met or a human handoff is required.",
              "messages": null
            }
          ],
          "flowTools": [],
          "buttonTool": null,
          "description": null,
          "carouselTool": null,
          "instructions": "Role: You are a knowledgeable Product Specialist for Syncora Systems. You are speaking to a potential client on the phone.\n\nGoal: Answer their technical questions accurately to build trust, but always pivot the conversation back to booking a demo or checking pricing.\n\nVoice Rules (CRITICAL):\n1. Be Concise: Your answers must be under 3 sentences. Do not read long lists. If the Knowledge Base has a long explanation, summarize the key benefit only.\n\n2. The \"Bridge\" Technique: After answering a question, do not go silent. Immediately follow up with a related value-add or a check-in question.\nBad: \"Yes, we integrate with Salesforce.\" (Silence)\nGood: \"Yes, we have a deep two-way sync with Salesforce. That way, your reps never have to do manual data entry. Does your team use Salesforce heavily?\"\n\n3. Handling \"Unknowns\": If you do not find the answer in the Knowledge Base, do not say \"I don't know.\" Instead, say: \"That’s a great question, but it gets a little technical. I'd love to have our Lead Engineer walk you through that on a quick demo. Would you be open to that?\"\n\nEscalation Logic:If the user seems satisfied with the answers , Ask: \"I think seeing this in action would really click for you. Do you want to set up that demo now?\"If the user asks for a human/operator, Route to Escalation.",
          "functionTools": [],
          "webSearchTool": null,
          "callForwardTool": null,
          "integrationTools": [],
          "knowledgeBaseTool": {
            "enabled": true,
            "description": "Searches an external knowledge base to retrieve relevant information, supplementing or replacing the language model's internal context."
          },
          "mcpIntegrationTools": []
        },

              "messages": null
            }
          ],
          "flowTools": [],
          "buttonTool": null,
          "description": null,
          "carouselTool": null,
          "instructions": "Express regret for not being able to assist fully and provide directions for further support or contact with a human agent.",
          "functionTools": [],

  "responseMessages": [
    {
      "id": "69425fd75d50142b9a48a39d",
      "discriminatorID": "69425fd75d50142b9a48a39c",
      "text": [
        {
          "text": [
            "I encountered a momentary glitch syncing with our central calendar, but don't worry—I have securely logged your details in our backup system.\n\nA member of our team will review your information manually and reach out to you shortly to finalize the next steps. Thank you for chatting with Syncora!"
          ]
        }
      ],
      "condition": null,
      "delay": null,
      "createdAt": "2025-12-17T07:46:32.000Z"
    },
    {
      "id": "6933d10338f22f865bba18c9",
      "discriminatorID": "6933d10338f22f865bba18c8",
      "text": [
        {
          "text": [
            "hi"
          ]
        }
      ],
      "condition": null,
      "delay": null,
      "createdAt": "2025-12-14T08:06:32.000Z"
    },
    {
      "id": "6943a4adf2cb16a962ad1ec1",
      "discriminatorID": "6943a4adf2cb16a962ad1ec0",
      "text": [
        {
          "text": [
            "Sorry, I missed that date. Could you say just the day and time again? For example, 'Tuesday at 2 PM"
          ]
        }
      ],
      "condition": null,
      "delay": null,
      "createdAt": "2025-12-18T06:52:30.000Z"
    },
    {
      "id": "6943a4d6f2cb16a962ad1ec5",
      "discriminatorID": "6943a4adf2cb16a962ad1ec0",
      "text": [
        {
          "text": [
            "I'm sorry, I missed that detail. Could you please repeat the time?"
          ]
        }
      ],
      "condition": null,
      "delay": null,
      "createdAt": "2025-12-18T06:53:11.000Z"
    },
    {

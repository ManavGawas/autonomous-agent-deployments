    {
      "id": "6933de8438f22f865bba1a6c",
      "name": "Business Email Validation",
      "createdByID": 1892778,
      "folderID": null,
      "settings": {},
      "description": "",
      "instructions": [
        {
          "text": [
            "You are an Email Validation Engine. Your job is to determine if ",
            {
              "variableID": "6933dd5f38f22f865bba1a4c"
            },
            " is a  valid \"Business\" email or a valid \"Personal\" email or \"Invalid Format\"\r\n\r\nInstructions:\r\n-If the domain is gmail.com, yahoo.com, hotmail.com, outlook.com, icloud.com, aol.com, protonmail.com, or live.com,  store \"true\" in variable invalid.\r\n-  If the input is not a standard email address (e.g. missing \"@\", missing \".com/.net/etc\") , store \"true\" in variable invalid."
          ]
        },
        {
          "text": [
            "-  If it is a valid email format AND the domain is NOT in the personal list above,store \"true\" in variable valid.\r\n- ONLY store the word \"valid\" or \"invalid\". Do not add punctuation."
          ]
        },
        {
          "text": [
            {
              "text": [
                ""
              ]
            }
          ]
        },
        {

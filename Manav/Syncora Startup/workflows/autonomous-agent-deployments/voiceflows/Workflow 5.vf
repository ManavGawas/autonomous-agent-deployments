      "prompts": {
        "6943e7eebf2b3aed1640d808": {
          "settings": {
            "useStructuredOutput": false,
            "model": "claude-4-sonnet",
            "maxTokens": 5000,
            "temperature": 0.3
          },
          "system": "",
          "messages": [
            {
              "role": "user",
              "content": "tell user this Message: \"Perfect. I've sent the pricing guide to your email. Check your inbox!\""
            }
          ]
        },
        "6942570d5d50142b9a48a388": {
          "settings": {
            "useStructuredOutput": false,
            "model": "claude-4-sonnet",
            "maxTokens": 5000,
            "temperature": 0.3
          },
          "system": "",
          "messages": [
            {
              "role": "user",
              "content": "Role: You are a seamless transition assistant for Syncora Systems.\n\nContext: The user has just provided their email address. You are about to query the database, which takes a few seconds.\n\nGoal: Acknowledge the email and fill the silence immediately to prevent the user from thinking the call has dropped.\n\nStrict Voice Rules:\n\nStatement ONLY: You must NOT ask a question. Do not say \"Is that correct?\" or \"Can you wait?\" because we are not waiting for an answer.\n\nBe Brief: Use less than 10 words.\n\nTone: Professional, efficient, and \"busy\" (like you are typing).\n\nApproved Phrases (Choose one randomly to sound natural):\n\n\"Thanks. Let me just pull up that file...\"\n\n\"Got it. Checking our records now...\"\n\n\"Understood. Syncing with the database, one moment...\"\n\n\"Okay, let me see what we have for that domain...\"\n\nOutput: Output ONLY the spoken phrase. Do not add any internal monologue."
            }
          ]
        },
        "6943a851bf2b3aed1640d7a6": {
          "settings": {
            "useStructuredOutput": false,
            "model": "claude-4-sonnet",
            "maxTokens": 5000,
            "temperature": 0.3
          },
          "system": "",
          "messages": [
            {
              "role": "user",
              "content": "Tell the user \"Perfect. I've locked that in for {requested_time}. You'll receive a calendar invite in your email shortly. Thanks for calling Syncora!\""
            }
          ]
        },
        "6943e368bf2b3aed1640d805": {
          "settings": {
            "useStructuredOutput": false,
            "model": "claude-4-sonnet",
            "maxTokens": 5000,
            "temperature": 0.3
          },
          "system": "",
          "messages": [
            {
              "role": "user",
              "content": "tell the user \"No problem. It might be easier to coordinate online. I've just texted you the calendar link so you can browse all available times. Talk soon!\""
            }
          ]
        },
        "69465e5d9095e34180f50022": {
          "settings": {
            "useStructuredOutput": false,
            "model": "claude-4-sonnet",
            "maxTokens": 5000,
            "temperature": 0.3
          },
          "system": "",
          "messages": [
            {
              "role": "user",
              "content": "Extract only the first name from the user's response.\r\nUser Response: {name}\r\n\r\nRules:\r\n1. If they say \"I am John\", return \"John\".\r\n2. If they say \"John\", return \"John\".\r\n3. If they say \"No\", return \"Valued Guest\".\r\n4. Return ONLY the name, no punctuation.\n\nBasically output {name}"
            }
          ]
        }
      },
      "apiTools": {},
      "messages": {
        "69465a01d5d80f230a073d03": {

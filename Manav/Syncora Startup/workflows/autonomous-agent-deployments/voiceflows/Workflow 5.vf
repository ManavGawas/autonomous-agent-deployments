    },
    {
      "id": "6947d1e9d5d80f230a076e16",
      "discriminatorID": "6947d1d8d5d80f230a076e0f",
      "text": [
        {
          "text": [
            "Wonderful, I've entered your information into our priority system. Now, let's arrange the demo. What day and time suits you this week?"
          ]
        }
      ],
      "condition": null,
      "delay": null,
      "createdAt": "2025-12-21T10:54:33.000Z"
    },
    {
      "id": "6947d1e9d5d80f230a076e18",
      "discriminatorID": "6947d1d8d5d80f230a076e0f",
      "text": [
        {
          "text": [
            "Fantastic, your information is now in our priority system. Let's lock in the demo. What day and time are convenient for you this week?"
          ]
        }
      ],
      "condition": null,
      "delay": null,
      "createdAt": "2025-12-21T10:54:33.000Z"
    },
    {
      "id": "6940220e04b0f0560f5a6816",
      "discriminatorID": "6940220e04b0f0560f5a6815",
      "text": [
        {
          "text": [
            "I encountered a momentary glitch syncing with our central calendar, but don't worry—I have securely logged your details in our backup system.\n\nA member of our team will review your information manually and reach out to you shortly to finalize the next steps. Thank you for chatting with Syncora!"
          ]
        }
      ],
      "condition": null,
      "delay": null,
      "createdAt": "2025-12-15T14:58:23.000Z"
    }
  ],

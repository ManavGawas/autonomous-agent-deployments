    {
      "id": "693289d02d0514000798562a",
      "name": "Standard plan path (self-serve)",
      "createdByID": 1892778,
      "folderID": null,
      "settings": {
        "model": "claude-4-sonnet",
        "maxTokens": 5000,
        "temperature": 0.3,
        "reasoningEffort": null
      },
      "description": null,
      "instructions": [

    {
      "id": "693289d02d05140007985629",
      "name": "VIP sales path (demo booking)",
      "createdByID": 1892778,
      "folderID": null,
      "settings": {
        "model": "claude-4-sonnet",
        "maxTokens": 5000,
        "temperature": 0.3,
        "reasoningEffort": null
      },
      "description": null,
      "instructions": [
